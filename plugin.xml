<?xml version="1.0" encoding="UTF-8"?>
<plugin
    id="enterprise-appstore-plugin"
    version="1.2.4"
    xmlns="http://apache.org/cordova/ns/plugins/1.0"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <name>EnterpriseAppStore</name>
    <description>Enterprise App Store Plugin - Download and Install Apps (Android + iOS)</description>
    <license>MIT</license>
    <keywords>cordova, outsystems, enterprise, appstore, download, install</keywords>

    <!-- Minimum engine requirements -->
    <engines>
        <engine name="cordova"         version=">=10.0.0" />
        <engine name="cordova-android" version=">=10.0.0" />
        <engine name="cordova-ios"     version=">=6.0.0"  />
    </engines>

    <!-- JavaScript bridge — exposes window.EnterpriseAppStore to the WebView -->
    <js-module src="www/EnterpriseAppStore.js" name="EnterpriseAppStore">
        <clobbers target="window.EnterpriseAppStore" />
    </js-module>

    <!-- ============================================================
         ANDROID
    ============================================================ -->
    <platform name="android">

        <!-- AndroidX dependencies required for FileProvider and DownloadManager -->
        <framework src="androidx.core:core:1.9.0" />
        <framework src="androidx.appcompat:appcompat:1.6.1" />

        <!-- Required permissions -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <!-- Network access for downloading APK files -->
            <uses-permission android:name="android.permission.INTERNET" />
            <!-- Required to install APK files programmatically -->
            <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
            <!-- Required on Android 11+ to query other installed packages -->
            <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
            <!-- External storage write access (Android 9 and below only) -->
            <uses-permission
                android:name="android.permission.WRITE_EXTERNAL_STORAGE"
                android:maxSdkVersion="28" />
            <!-- External storage read access (Android 12 and below only) -->
            <uses-permission
                android:name="android.permission.READ_EXTERNAL_STORAGE"
                android:maxSdkVersion="32" />
        </config-file>

        <!-- Register custom FileProvider to serve APK files via content:// URI.
             Uses a dedicated subclass to avoid authority conflicts with other plugins. -->
        <config-file target="AndroidManifest.xml" parent="application">
            <provider
                android:name="com.enterprise.appstore.EnterpriseAppStoreFileProvider"
                android:authorities="${applicationId}.enterprise.appstore.provider"
                android:exported="false"
                android:grantUriPermissions="true">
                <meta-data
                    android:name="android.support.FILE_PROVIDER_PATHS"
                    android:resource="@xml/enterprise_appstore_paths" />
            </provider>
        </config-file>

        <!-- Register plugin feature with Cordova -->
        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="EnterpriseAppStore">
                <param name="android-package"
                       value="com.enterprise.appstore.EnterpriseAppStore" />
            </feature>
        </config-file>

        <!-- Java source files -->
        <source-file
            src="src/android/EnterpriseAppStore.java"
            target-dir="src/com/enterprise/appstore" />
        <source-file
            src="src/android/EnterpriseAppStoreFileProvider.java"
            target-dir="src/com/enterprise/appstore" />

        <!-- FileProvider path configuration (defines accessible directories) -->
        <resource-file
            src="res/android/xml/enterprise_appstore_paths.xml"
            target="res/xml/enterprise_appstore_paths.xml" />

    </platform>

    <!-- ============================================================
         iOS
    ============================================================ -->
    <platform name="ios">

        <!-- 1. Register plugin feature with Cordova -->
        <config-file target="config.xml" parent="/*">
            <feature name="EnterpriseAppStore">
                <param name="ios-package" value="EnterpriseAppStore" />
            </feature>
        </config-file>

        <!-- 2. Declare URL schemes that can be queried via canOpenURL().
                Required for isAppInstalled() on iOS 9+.
                Add URL scheme of each app you want to check.
                "cydia" is used for jailbreak detection in checkAppShield(). -->
        <config-file target="*-Info.plist"
                     parent="LSApplicationQueriesSchemes">
            <array>
                <string>EnterpriseAppStore_2</string>
                <string>New IOS App</string>
                <!-- Add more URL schemes here as needed -->
                <!-- <string>hrconnect</string> -->
                <!-- <string>timekeeping</string> -->
            </array>
        </config-file>

        <!-- 3. App Transport Security — enforce HTTPS for OTA installation.
                NSExceptionDomains key must be the domain name ONLY,
                without "https://" prefix. -->
        <config-file target="*-Info.plist"
                     parent="NSAppTransportSecurity">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <false/>
                <key>NSExceptionDomains</key>
                <dict>
                    <key>hscl-dev.outsystemscloud.com</key>
                    <dict>
                        <key>NSIncludesSubdomains</key>
                        <true/>
                        <key>NSExceptionAllowsInsecureHTTPLoads</key>
                        <false/>
                    </dict>
                </dict>
            </dict>
        </config-file>

        <!-- 4. UIKit framework — required for UIDevice, UIScreen, UIApplication -->
        <framework src="UIKit.framework" weak="false" />

        <!-- 5. Swift source file -->
        <source-file src="src/ios/EnterpriseAppStore.swift" />

        <!-- Note: cordova-plugin-add-swift-support is NOT required for MABS 10+ -->

    </platform>

</plugin>
