<?xml version="1.0" encoding="UTF-8"?>
<plugin
    id="enterprise-appstore-plugin"
    version="1.3.1"
    xmlns="http://apache.org/cordova/ns/plugins/1.0"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <name>EnterpriseAppStore</name>
    <description>Enterprise App Store Plugin - Download, Install, Device Info, Open App (Android + iOS)</description>
    <license>MIT</license>
    <keywords>cordova, outsystems, enterprise, appstore, download, install, openapp, deviceinfo</keywords>

    <engines>
        <engine name="cordova"         version=">=10.0.0" />
        <engine name="cordova-android" version=">=10.0.0" />
        <engine name="cordova-ios"     version=">=6.0.0"  />
    </engines>

    <js-module src="www/EnterpriseAppStore.js" name="EnterpriseAppStore">
        <clobbers target="window.EnterpriseAppStore" />
    </js-module>

    <!-- ============================================================
         ANDROID
    ============================================================ -->
    <platform name="android">

        <framework src="androidx.core:core:1.12.0" />
        <framework src="androidx.appcompat:appcompat:1.6.1" />

        <!-- ✅ PERMISSIONS - Scoped Storage -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
            <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

            <uses-permission android:name="android.intent.action.BADGE_COUNT_UPDATE" />
            <uses-permission android:name="me.leolin.shortcutbadger.BADGE_COUNT_UPDATE" />
            <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
            
            <!-- POST_NOTIFICATIONS for badge (Android 13+) -->
            <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
            
            <!-- Legacy permissions for older Android -->
            <uses-permission
                android:name="android.permission.WRITE_EXTERNAL_STORAGE"
                android:maxSdkVersion="28" />
            <uses-permission
                android:name="android.permission.READ_EXTERNAL_STORAGE"
                android:maxSdkVersion="32" />
        </config-file>

        <!-- FileProvider -->
        <config-file target="AndroidManifest.xml" parent="application">
            <provider
                android:name="com.enterprise.appstore.EnterpriseAppStoreFileProvider"
                android:authorities="${applicationId}.enterprise.appstore.provider"
                android:exported="false"
                android:grantUriPermissions="true">
                <meta-data
                    android:name="android.support.FILE_PROVIDER_PATHS"
                    android:resource="@xml/enterprise_appstore_paths" />
            </provider>
        </config-file>

        <!-- Cordova feature -->
        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="EnterpriseAppStore">
                <param name="android-package"
                       value="com.enterprise.appstore.EnterpriseAppStore" />
            </feature>
        </config-file>

        <!-- Java source files -->
        <source-file
            src="src/android/EnterpriseAppStore.java"
            target-dir="src/com/enterprise/appstore" />
        <source-file
            src="src/android/EnterpriseAppStoreFileProvider.java"
            target-dir="src/com/enterprise/appstore" />

        <!-- FileProvider paths config -->
        <resource-file
            src="res/android/xml/enterprise_appstore_paths.xml"
            target="res/xml/enterprise_appstore_paths.xml" />

    </platform>

    <!-- ============================================================
         iOS
    ============================================================ -->
    <platform name="ios">
         <!-- Register plugin -->
        <config-file target="config.xml" parent="/*">
            <feature name="EnterpriseAppStore">
                <param name="ios-package" value="EnterpriseAppStore" />
            </feature>
        </config-file>

        <!-- URL Schemes for OTA install and jailbreak detection -->
        <config-file target="*-Info.plist" parent="LSApplicationQueriesSchemes">
            <array>
                <string>itms-services</string>
                <string>cydia</string>
            </array>
        </config-file>

        <!-- ATS exception for IPSW.me API -->
        <config-file target="*-Info.plist" parent="NSAppTransportSecurity">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <false/>
                <key>NSExceptionDomains</key>
                <dict>
                    <key>api.ipsw.me</key>
                    <dict>
                        <key>NSExceptionAllowsInsecureHTTPLoads</key>
                        <false/>
                        <key>NSIncludesSubdomains</key>
                        <true/>
                        <key>NSExceptionRequiresForwardSecrecy</key>
                        <false/>
                        <key>NSExceptionMinimumTLSVersion</key>
                        <string>TLSv1.2</string>
                    </dict>
                </dict>
            </dict>
        </config-file>

        <!-- Source files -->
        <header-file src="src/ios/EnterpriseAppStore.h" />
        <source-file src="src/ios/EnterpriseAppStore.m" />

        <!-- Frameworks -->
        <framework src="UserNotifications.framework" />
        <framework src="Security.framework" />
        <framework src="UIKit.framework" />
    </platform>

</plugin>
