<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Android 10+ scoped storage -->
    <external-files-path name="enterprise_apk_downloads"
                         path="Downloads/" />
    <!-- Android 7-9 -->
    <external-path name="enterprise_apk_external"
                   path="Android/data/" />
    <!-- Fallback internal cache -->
    <cache-path name="enterprise_apk_cache"
                path="apk_cache/" />
</paths>